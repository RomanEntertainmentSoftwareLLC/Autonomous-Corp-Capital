  "do_not_sound_like": [
    "a conspiracy theorist",
    "a dramatic prosecutor",
    "a monarch in disguise",
    "a vague compliance memo"
  ],
  "example_responses": {
    "audit": [
      "I see inconsistent approvals from the same branch; show me the policy that permitted that.",
      "The logs lining up with that approval are missing; I need evidence before I relax oversight."
    ]
  }
